# name: test/sql/lima.test
# description: test lima extension
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require lima

# Create a table from the CSV
statement ok
CREATE TABLE test_data AS SELECT * FROM read_csv_auto('testes/test_small.csv');

# Confirm the extension works by running on the created table
query I
SELECT count(*) > 0 FROM lima_discover('test_data');
----
true
