#define DUCKDB_EXTENSION_MAIN

#include "duckteste_extension.hpp"
#include "lima_structures.hpp"
#include "duckdb.hpp"
#include <random>
#include <unordered_map>
#include "duckdb/common/exception.hpp"
#include "duckdb/function/table_function.hpp"
#include "duckdb/common/types/column/column_data_collection.hpp"
#include "duckdb/main/database.hpp"
#include "duckdb/catalog/catalog_entry/table_catalog_entry.hpp"
#include "duckdb/transaction/duck_transaction.hpp"
#include "duckdb/storage/table/scan_state.hpp"
#include "duckdb/storage/table_storage_info.hpp"
#include <optional>
#include <thread>
#include <cstdio>
#include <algorithm>

namespace duckdb {

struct MaterializedColumn {
    LogicalType type;
    vector<int64_t> i_data; 
    vector<double> d_data;  
    vector<int8_t> is_null; 
    bool is_numeric;
    bool is_constant;
};

struct LimaDiscoverBindData : public TableFunctionData {
    string table_name;
    LimaSchema schema;
    double min_grad;
};

struct LimaDiscoverGlobalState : public GlobalTableFunctionState {
    bool finished = false;
    unordered_map<LimaNode, unique_ptr<LimaNode>, LimaNodeHash> nodes;
    LimaNode* root;
    vector<MaterializedColumn> materialized_columns;
    unordered_map<string, int64_t> string_maps;
    idx_t total_rows = 0;
    std::mt19937 rng;
    vector<vector<uint64_t>> predicate_results;
    idx_t num_samples = 0;
    idx_t num_words = 0;
    vector<string> discovered_constraints;
    idx_t result_idx = 0;

    LimaDiscoverGlobalState(idx_t num_cols) : rng(42) {
        auto empty_root = make_uniq<LimaNode>(num_cols);
        empty_root->CalculateHash();
        root = empty_root.get();
        nodes[(*empty_root)] = std::move(empty_root);
        materialized_columns.resize(num_cols);
    }

    LimaNode* GetOrCreateNode(const LimaNode& n) {
        auto it = nodes.find(n);
        if (it != nodes.end()) return it->second.get();
        auto new_node = make_uniq<LimaNode>(n);
        new_node->CalculateHash();
        auto* ptr = new_node.get();
        nodes[n] = std::move(new_node);
        return ptr;
    }

    void AddSamplesInBatch(idx_t n, const LimaSchema& schema, const vector<idx_t>& active_idxs) {
        idx_t start_batch_idx = num_samples;
        num_samples += n;
        num_words = (num_samples + 63) / 64;
        for (idx_t i = 0; i < predicate_results.size(); i++) predicate_results[i].resize(num_words, 0);

        std::uniform_int_distribution<idx_t> dist(0, total_rows - 1);
        vector<idx_t> r1_batch(n), r2_batch(n);
        for(idx_t i=0; i<n; i++) {
            r1_batch[i] = dist(rng); r2_batch[i] = dist(rng);
            while (r1_batch[i] == r2_batch[i]) r2_batch[i] = dist(rng);
        }

        for (idx_t p_idx : active_idxs) {
            auto &pred = schema.all_predicates[p_idx];
            auto &col = materialized_columns[pred.col_idx];
            const int8_t* nulls = col.is_null.data();
            auto& bits = predicate_results[p_idx];
            
            if (col.is_numeric) {
                const double* data = col.d_data.data();
                for (idx_t i = 0; i < n; i++) {
                    idx_t r1 = r1_batch[i], r2 = r2_batch[i];
                    if (nulls[r1] || nulls[r2]) continue; // Numbers: NaNs don't match (Java behavior)
                    bool res = false; double v1 = data[r1], v2 = data[r2];
                    switch (pred.op) {
                        case LimaOperator::EQ: res = (v1 == v2); break;
                        case LimaOperator::NE: res = (v1 != v2); break;
                        case LimaOperator::GT: res = (v1 > v2); break;
                        case LimaOperator::GE: res = (v1 >= v2); break;
                        case LimaOperator::LT: res = (v1 < v2); break;
                        case LimaOperator::LE: res = (v1 <= v2); break;
                    }
                    if (res) bits[(start_batch_idx + i) / 64] |= (1ULL << ((start_batch_idx + i) % 64));
                }
            } else {
                const int64_t* data = col.i_data.data();
                for (idx_t i = 0; i < n; i++) {
                    idx_t r1 = r1_batch[i], r2 = r2_batch[i];
                    // Strings: NULLs match NULLs in Java's encoded string arrays
                    int64_t v1 = data[r1], v2 = data[r2];
                    bool res = (pred.op == LimaOperator::EQ) ? (v1 == v2) : (v1 != v2);
                    if (res) bits[(start_batch_idx + i) / 64] |= (1ULL << ((start_batch_idx + i) % 64));
                }
            }
        }
    }
};

static vector<uint64_t> GetNodeBitset(LimaDiscoverGlobalState &state, LimaNode &node, const LimaSchema& schema) {
    vector<uint64_t> res(state.num_words, ~0ULL); bool empty = true;
    for (size_t i = 0; i < node.predicate_ids.size(); i++) {
        if (node.predicate_ids[i] != -1) {
            empty = false; idx_t p_idx = 0; bool found = false;
            for(auto &p : schema.all_predicates) {
                if (p.col_idx == (idx_t)i && (int8_t)p.op == node.predicate_ids[i]) { found = true; break; }
                p_idx++;
            }
            if (found) { const auto& p_bits = state.predicate_results[p_idx]; for (idx_t w = 0; w < state.num_words; w++) res[w] &= p_bits[w]; }
        }
    }
    if (empty) return vector<uint64_t>(state.num_words, ~0ULL);
    return res;
}

void PropagateAcross(LimaDiscoverGlobalState &state, LimaNode* from, LimaNode* to, idx_t col_idx, const LimaSchema& schema) {
    auto from_bits = GetNodeBitset(state, *from, schema);
    auto to_bits = GetNodeBitset(state, *to, schema);
    idx_t a = 0; for (auto w : to_bits) a += __builtin_popcountll(w);
    to->dist.a = 1 + a; to->dist.b = 1 + (state.num_samples - a); to->dist.updateStats();

    idx_t from_a = 0;
    bool root_from = true; for(auto pid : from->predicate_ids) if(pid != -1) root_from = false;
    if (root_from) from_a = state.num_samples; 
    else { for (auto w : from_bits) from_a += __builtin_popcountll(w); }

    to->edge_dist.a = 1 + a; to->edge_dist.b = 1 + (from_a - a); to->edge_dist.updateStats();
    to->sound = true;

    for (size_t i = 0; i < to->predicate_ids.size(); i++) {
        if (to->predicate_ids[i] != -1 && i != col_idx) {
            LimaNode p_struct = *to; p_struct.predicate_ids[i] = -1; p_struct.CalculateHash();
            LimaNode* parent = state.GetOrCreateNode(p_struct);
            BetaDistribution p_edge_dist; auto p_bits = GetNodeBitset(state, *parent, schema);
            idx_t pa = 0; for (auto w : p_bits) pa += __builtin_popcountll(w);
            p_edge_dist.a = 1 + a; p_edge_dist.b = 1 + (pa - a); p_edge_dist.updateStats();
            double comb_sd = std::sqrt(p_edge_dist.sdLogOdds * p_edge_dist.sdLogOdds + to->edge_dist.sdLogOdds * to->edge_dist.sdLogOdds);
            if ((p_edge_dist.meanLogOdds - to->edge_dist.meanLogOdds) / comb_sd < 2.0) { to->sound = false; break; }
        }
    }

    if (to->sound && a == 0) {
        state.discovered_constraints.push_back(to->ToString(schema));
    } else if (to->sound) {
        fprintf(stderr, "  [LIMA C++] Node %s is sound (violations: %llu). Going deeper...\n", to->ToString(schema).c_str(), (unsigned long long)a);
    }
}

void SearchSorted(LimaDiscoverGlobalState &state, LimaNode* node, idx_t last_p_idx, const vector<idx_t>& sorted_p_idxs, const LimaSchema& schema, double min_grad) {
    if (node->dist.a == 1) return;
    for (idx_t i = 0; i < last_p_idx; i++) {
        idx_t p_idx = sorted_p_idxs[i]; auto &pred = schema.all_predicates[p_idx];
        if (node->predicate_ids[pred.col_idx] != -1) continue;
        LimaNode sp_struct(schema.columns.size()); sp_struct.predicate_ids[pred.col_idx] = (int8_t)pred.op; sp_struct.CalculateHash();
        if (state.nodes[sp_struct]->dist.grad <= min_grad) continue;
        LimaNode next_struct = *node; next_struct.predicate_ids[pred.col_idx] = (int8_t)pred.op; next_struct.CalculateHash();
        LimaNode* next_node = state.GetOrCreateNode(next_struct);
        PropagateAcross(state, node, next_node, pred.col_idx, schema);
        if (next_node->sound) SearchSorted(state, next_node, i, sorted_p_idxs, schema, min_grad);
    }
}

unique_ptr<FunctionData> LimaDiscoverBind(ClientContext &context, TableFunctionBindInput &input, vector<LogicalType> &return_types, vector<string> &names) {
    auto table_name = input.inputs[0].GetValue<string>();
    double aprox = 0.00001; if (input.inputs.size() > 1) aprox = input.inputs[1].GetValue<double>();
    auto &catalog = Catalog::GetCatalog(context, INVALID_CATALOG);
    auto &table_entry = catalog.GetEntry(context, CatalogType::TABLE_ENTRY, DEFAULT_SCHEMA, table_name).Cast<TableCatalogEntry>();
    auto result = make_uniq<LimaDiscoverBindData>(); result->table_name = table_name; result->min_grad = aprox * 0.01;
    vector<string> col_names; vector<LogicalType> col_types;
    for (auto &col : table_entry.GetColumns().Logical()) { col_names.push_back(col.GetName()); col_types.push_back(col.GetType()); }
    result->schema.Initialize(col_names, col_types); result->schema.Print(stderr);
    return_types.push_back(LogicalType::VARCHAR); names.push_back("denial_constraint");
    return std::move(result);
}

unique_ptr<GlobalTableFunctionState> LimaDiscoverInit(ClientContext &context, TableFunctionInitInput &input) {
    auto &bind_data = (LimaDiscoverBindData &)*input.bind_data;
    auto &catalog = Catalog::GetCatalog(context, INVALID_CATALOG);
    auto &table_entry = catalog.GetEntry(context, CatalogType::TABLE_ENTRY, DEFAULT_SCHEMA, bind_data.table_name).Cast<TableCatalogEntry>();
    auto table_types = table_entry.GetTypes(); auto state = make_uniq<LimaDiscoverGlobalState>(table_types.size());
    state->total_rows = table_entry.GetStorage().GetTotalRows();
    auto &transaction = DuckTransaction::Get(context, catalog); auto &storage = table_entry.GetStorage();
    TableScanState scan_state; vector<StorageIndex> column_ids;
    for (idx_t i = 0; i < table_types.size(); i++) {
        column_ids.emplace_back(i);
        state->materialized_columns[i].type = table_types[i];
        state->materialized_columns[i].is_numeric = table_types[i].IsNumeric();
        state->materialized_columns[i].is_constant = true;
    }
    storage.InitializeScan(context, transaction, scan_state, column_ids); DataChunk scan_chunk; scan_chunk.Initialize(context, table_types);
    int64_t string_id_counter = 1;
    while (true) {
        scan_chunk.Reset(); storage.Scan(transaction, scan_chunk, scan_state); if (scan_chunk.size() == 0) break;
        for (idx_t c = 0; c < table_types.size(); c++) {
            auto &m_col = state->materialized_columns[c];
            for (idx_t r = 0; r < scan_chunk.size(); r++) {
                auto val = scan_chunk.GetValue(c, r);
                if (val.IsNull()) { 
                    m_col.is_null.push_back(1); m_col.i_data.push_back(0); m_col.d_data.push_back(0.0);
                } else {
                    m_col.is_null.push_back(0);
                    if (m_col.is_numeric) {
                        double d_val = val.GetValue<double>(); if (!m_col.d_data.empty() && d_val != m_col.d_data[0]) m_col.is_constant = false;
                        m_col.d_data.push_back(d_val); m_col.i_data.push_back(0);
                    } else {
                        string s = val.ToString(); if (state->string_maps.find(s) == state->string_maps.end()) state->string_maps[s] = string_id_counter++;
                        int64_t i_val = state->string_maps[s]; if (!m_col.i_data.empty() && i_val != m_col.i_data[0]) m_col.is_constant = false;
                        m_col.i_data.push_back(i_val); m_col.d_data.push_back(0.0);
                    }
                }
            }
        }
    }
    fprintf(stderr, ">>> [LIMA] Table materialized. Rows: %llu\n", (unsigned long long)state->total_rows);
    return std::move(state);
}

void LimaDiscoverFunction(ClientContext &context, TableFunctionInput &data_p, DataChunk &output) {
    auto &state = (LimaDiscoverGlobalState &)*data_p.global_state; auto &bind_data = (LimaDiscoverBindData &)*data_p.bind_data;
    if (state.result_idx < state.discovered_constraints.size()) {
        idx_t count = 0; auto res_ptr = FlatVector::GetData<string_t>(output.data[0]);
        while (count < STANDARD_VECTOR_SIZE && state.result_idx < state.discovered_constraints.size()) {
            res_ptr[count++] = StringVector::AddString(output.data[0], state.discovered_constraints[state.result_idx++]);
        }
        output.SetCardinality(count); return;
    }
    if (state.finished) { output.SetCardinality(0); return; }

    state.predicate_results.resize(bind_data.schema.all_predicates.size());
    double target = (double)state.total_rows * state.total_rows * 0.0325;
    idx_t total = 0, b_idx = 0; vector<idx_t> active;
    for(idx_t i=0; i<bind_data.schema.all_predicates.size(); i++) {
        auto &p = bind_data.schema.all_predicates[i];
        if (state.materialized_columns[p.col_idx].is_constant && (p.op != LimaOperator::EQ)) {
            LimaNode n(state.materialized_columns.size()); n.predicate_ids[p.col_idx] = (int8_t)p.op; auto* node = state.GetOrCreateNode(n); node->dist.add(0, 1000000); node->dist.updateStats();
        } else active.push_back(i);
    }
    vector<string> col_names; for (auto &col : bind_data.schema.columns) col_names.push_back(col.name);
    fprintf(stderr, ">>> [LIMA C++] Batching (Target: %f, MinGrad: %f)...\n", target, bind_data.min_grad);

    while (total < target && !active.empty()) {
        idx_t n = 100 * (1 << b_idx); state.AddSamplesInBatch(n, bind_data.schema, active); total += n; b_idx++;
        vector<idx_t> next; for (idx_t p : active) {
            auto &pr = bind_data.schema.all_predicates[p];
            LimaNode ln(state.materialized_columns.size()); ln.predicate_ids[pr.col_idx] = (int8_t)pr.op;
            auto* node = state.GetOrCreateNode(ln); idx_t a = 0; const auto& p_bits = state.predicate_results[p];
            for (idx_t w = 0; w < state.num_words; w++) a += __builtin_popcountll(p_bits[w]);
            node->dist.a = 1+a; node->dist.b = 1+(state.num_samples-a); node->dist.updateStats();
            if (node->dist.grad > bind_data.min_grad) next.push_back(p);
            else fprintf(stderr, "  [LIMA C++] Pruning Predicate %llu: %s (grad: %f) at batch %llu\n", (unsigned long long)p, pr.ToString(col_names).c_str(), node->dist.grad, (unsigned long long)b_idx);
        }
        active = next;
    }
    vector<pair<idx_t, double>> sorted;
    for (idx_t p_idx : active) {
        auto &pr = bind_data.schema.all_predicates[p_idx];
        LimaNode ln(state.materialized_columns.size()); ln.predicate_ids[pr.col_idx] = (int8_t)pr.op;
        sorted.push_back({p_idx, state.GetOrCreateNode(ln)->dist.meanLogOdds});
    }
    std::sort(sorted.begin(), sorted.end(), [](const pair<idx_t,double>& a, const pair<idx_t,double>& b) { return a.second > b.second; });
    vector<idx_t> sorted_idxs; for(auto &p : sorted) sorted_idxs.push_back(p.first);
    
    fprintf(stderr, ">>> [LIMA C++] Starting Search from %llu points...\n", (unsigned long long)sorted_idxs.size());
    for (idx_t i = 0; i < sorted_idxs.size(); i++) {
        idx_t p_idx = sorted_idxs[i]; auto &pr = bind_data.schema.all_predicates[p_idx];
        LimaNode ln(state.materialized_columns.size()); ln.predicate_ids[pr.col_idx] = (int8_t)pr.op;
        auto* node = state.GetOrCreateNode(ln);
        idx_t a = 0; auto bits = GetNodeBitset(state, *node, bind_data.schema);
        for (auto w : bits) a += __builtin_popcountll(w);
        if (a == 0) {
            state.discovered_constraints.push_back(node->ToString(bind_data.schema));
        } else { SearchSorted(state, node, i, sorted_idxs, bind_data.schema, bind_data.min_grad); }
    }
    state.finished = true; LimaDiscoverFunction(context, data_p, output);
}

void RegisterLimaDiscover(ExtensionLoader &loader) {
    TableFunctionSet set("lima_discover");
    set.AddFunction(TableFunction({LogicalType::VARCHAR}, LimaDiscoverFunction, LimaDiscoverBind, LimaDiscoverInit));
    set.AddFunction(TableFunction({LogicalType::VARCHAR, LogicalType::DOUBLE}, LimaDiscoverFunction, LimaDiscoverBind, LimaDiscoverInit));
    loader.RegisterFunction(set);
}

void RegisterEvidenceSet(ExtensionLoader &loader) { }

static void LoadInternal(ExtensionLoader &loader) {
    auto duckteste_scalar_function = ScalarFunction("duckteste", {LogicalType::VARCHAR}, LogicalType::VARCHAR, [](DataChunk &args, ExpressionState &state, Vector &result) {
        auto &name_vector = args.data[0];
        UnaryExecutor::Execute<string_t, string_t>(name_vector, result, args.size(), [&](string_t name) {
            return StringVector::AddString(result, "Duckteste " + name.GetString() + " 🐥");
        });
    });
    loader.RegisterFunction(duckteste_scalar_function);
    RegisterLimaDiscover(loader);
}

void DucktesteExtension::Load(ExtensionLoader &loader) { LoadInternal(loader); }
std::string DucktesteExtension::Name() { return "duckteste"; }
std::string DucktesteExtension::Version() const { return "0.1"; }

} // namespace duckdb

extern "C" {
DUCKDB_CPP_EXTENSION_ENTRY(duckteste, loader) { duckdb::LoadInternal(loader); }
}
